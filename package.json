{
  "name": "@dapi/docmost-cli",
  "version": "2.2.0",
  "description": "A CLI for Docmost, allowing automation and documentation management from the terminal.",
  "main": "build/index.js",
  "bin": {
    "docmost": "build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "watch": "tsc --watch"
  },
  "keywords": [
    "cli",
    "docmost",
    "documentation",
    "ai",
    "agent"
  ],
  "author": "Moritz Krause",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@hocuspocus/provider": "^3.4.4",
    "@hocuspocus/transformer": "^3.4.4",
    "@tiptap/core": "^3.18.0",
    "@tiptap/extension-image": "^3.18.0",
    "@tiptap/extension-link": "^3.18.0",
    "@tiptap/extension-table": "^3.20.1",
    "@tiptap/extension-table-cell": "^3.20.1",
    "@tiptap/extension-table-header": "^3.20.1",
    "@tiptap/extension-table-row": "^3.20.1",
    "@tiptap/html": "^3.18.0",
    "@tiptap/starter-kit": "^3.18.0",
    "axios": "^1.6.0",
    "commander": "^14.0.1",
    "form-data": "^4.0.0",
    "jsdom": "^27.4.0",
    "marked": "^17.0.1",
    "ws": "^8.19.0",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@types/form-data": "^2.5.0",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
